# ─── Application ────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-this-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost
LOG_LEVEL=INFO

# ─── Database ───────────────────────────────────────────
DB_PASSWORD=change-this-password
DATABASE_URL=postgresql+asyncpg://quant:${DB_PASSWORD}@postgres:5432/quantdb

# ─── Redis ──────────────────────────────────────────────
REDIS_PASSWORD=change-this-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ─── Broker: Shoonya (Finvasia) — PRIMARY, FREE ─────────
SHOONYA_USER_ID=your_user_id
SHOONYA_PASSWORD=your_password
SHOONYA_TOTP_SECRET=your_totp_secret
SHOONYA_API_KEY=your_api_key
SHOONYA_VENDOR_CODE=your_vendor_code
SHOONYA_IMEI=noimeiespecified

# ─── Broker: Angel One SmartAPI — FALLBACK, FREE ────────
ANGEL_API_KEY=your_api_key
ANGEL_CLIENT_ID=your_client_id
ANGEL_PASSWORD=your_password
ANGEL_TOTP_SECRET=your_totp_secret

# ─── Telegram Bot ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_numeric_chat_id

# ─── Risk Defaults (overrideable via UI settings) ───────
RISK_PER_TRADE_PCT=0.01
MAX_DAILY_LOSS_INR=500
MAX_DAILY_LOSS_PCT=0.02
MAX_ACCOUNT_DRAWDOWN_PCT=0.10
COOLDOWN_MINUTES=15
MIN_ATR_PCT=0.003
MAX_ATR_PCT=0.030
MAX_POSITION_PCT=0.20
MAX_CONCURRENT_POSITIONS=2
